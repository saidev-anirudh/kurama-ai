{
  "name": "portfolio-ai",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev:web": "pnpm --filter @portfolio/web dev",
    "build:web": "pnpm --filter @portfolio/web build",
    "lint:web": "pnpm --filter @portfolio/web lint",
    "typecheck:contracts": "pnpm --filter @portfolio/contracts build",
    "dev:up": "bash ./scripts/dev-up.sh",
    "check:base": "bash ./scripts/base-check.sh",
    "dev:logs": "bash ./scripts/dev-logs.sh"
  }
}
